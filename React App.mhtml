.panel-metric-row p, .support-item p, .tracking-result p, .review-box p, .e=
mpty-state, .status-message, .cart-item p { margin: 0px; font-size: 0.95rem=
; }

.panel-note { margin: 0px; }

.content-grid { display: grid; grid-template-columns: minmax(0px, 1.55fr) m=
inmax(320px, 0.75fr); gap: 24px; align-items: start; }

.catalog { padding: 28px; }

.section-heading { display: flex; gap: 18px; align-items: end; justify-cont=
ent: space-between; margin-bottom: 20px; }

.section-heading.compact { align-items: center; }

.section-heading h2 { font-size: clamp(1.6rem, 2vw, 2.2rem); }

.section-summary { max-width: 38ch; margin: 0px; }

.toolbar { display: grid; grid-template-columns: repeat(3, minmax(0px, 1fr)=
); gap: 14px; margin-bottom: 20px; }

.field { display: flex; flex-direction: column; gap: 8px; }

.field span { font-size: 0.85rem; font-weight: 700; color: var(--muted); }

.field input, .field select, .track-form input { width: 100%; border: 1px s=
olid rgba(31, 41, 55, 0.12); border-radius: 16px; padding: 0.95rem 1rem; ba=
ckground: rgba(255, 255, 255, 0.9); color: var(--ink); font: inherit; }

.field input:focus, .field select:focus, .track-form input:focus { outline:=
 rgba(231, 111, 81, 0.35) solid 2px; outline-offset: 2px; }

.product-grid { display: grid; grid-template-columns: repeat(2, minmax(0px,=
 1fr)); gap: 18px; }

.product-card { background: rgba(255, 255, 255, 0.7); border: 1px solid rgb=
a(31, 41, 55, 0.08); border-radius: 24px; overflow: hidden; transition: tra=
nsform 180ms, box-shadow 180ms, border-color 180ms; }

.product-card.active, .product-card:hover { transform: translateY(-2px); bo=
rder-color: rgba(231, 111, 81, 0.35); box-shadow: rgba(24, 32, 44, 0.12) 0p=
