-content: space-between; gap: 22px; }

.panel-label, .section-heading p { margin: 0px 0px 6px; text-transform: upp=
ercase; letter-spacing: 0.14em; color: var(--muted); font-size: 0.72rem; fo=
nt-weight: 700; }

.panel-metric-row { display: grid; grid-template-columns: repeat(3, minmax(=
0px, 1fr)); gap: 14px; }

.panel-metric-row div, .support-item, .review-box, .tracking-result, .cart-=
summary, .cart-item { background: rgba(255, 255, 255, 0.72); border: 1px so=
lid rgba(31, 41, 55, 0.08); border-radius: 18px; }

.panel-metric-row div { padding: 18px; }

.panel-metric-row span { display: block; font-size: 1.4rem; font-family: Fr=
