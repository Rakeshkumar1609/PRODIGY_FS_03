.cart-list { display: grid; gap: 12px; margin: 18px 0px; }

.cart-item, .support-item { padding: 14px 16px; }

.cart-item { flex-wrap: wrap; }

.cart-controls { display: inline-flex; align-items: center; gap: 10px; bord=
er: 1px solid rgba(31, 41, 55, 0.1); border-radius: 999px; padding: 4px; }

.cart-controls button, .secondary-button, .primary-button { border: 0px; bo=
rder-radius: 999px; font: inherit; cursor: pointer; }

.cart-controls button { width: 32px; height: 32px; border-radius: 50%; back=
ground: rgba(31, 41, 55, 0.08); color: var(--ink); }

.cart-summary { flex-direction: column; align-items: stretch; gap: 14px; pa=
dding: 16px; }

.cart-summary > div { display: flex; justify-content: space-between; gap: 1=
0px; }

.primary-button, .secondary-button { padding: 0.95rem 1.2rem; font-weight: =
700; transition: transform 180ms, background 180ms; }

.primary-button { background: linear-gradient(135deg, var(--accent), #f59e0=
b); color: rgb(255, 255, 255); }

.primary-button:hover, .secondary-button:hover { transform: translateY(-1px=
); }

.secondary-button { background: rgba(31, 41, 55, 0.08); color: var(--ink); =
}

.full-width { width: 100%; }

.review-box, .tracking-result { display: grid; gap: 10px; padding: 16px; ma=
rgin-top: 14px; }

.review-box span { font-weight: 700; }

.track-form { display: grid; gap: 12px; margin: 14px 0px; }

.tracking-result strong { font-size: 1.05rem; }

.progress-bar { width: 100%; height: 10px; border-radius: 999px; background=
: rgba(31, 41, 55, 0.08); overflow: hidden; }

.progress-bar span { display: block; height: 100%; border-radius: inherit; =
background: linear-gradient(90deg, var(--accent), #f59e0b); }

.support-panel { display: grid; gap: 12px; }

.support-item { align-items: flex-start; flex-direction: column; }

.empty-state, .status-message { padding: 12px 0px 4px; }

@media (max-width: 1080px) {
  .hero, .content-grid { grid-template-columns: 1fr; }
  .toolbar, .product-grid, .panel-metric-row { grid-template-columns: 1fr; =
}
}

@media (max-width: 720px) {
  .app-shell { padding: 16px; }
  .hero-copy, .hero-panel, .catalog, .sidebar > section { border-radius: 22=
px; padding: 20px; }
  .section-heading { align-items: flex-start; flex-direction: column; }
}
